# Stripe (Dashboard → Developers → API keys)

# Use test keys locally; live keys in production (e.g. Vercel env vars).

STRIPE_SECRET_KEY=sk_test_...



# Stripe webhook signing secret (Dashboard → Developers → Webhooks → checkout.session.completed)

STRIPE_WEBHOOK_SECRET=whsec_...



# Signs registration cookies (use a long random string in production)

REGISTRATION_SECRET=change-me-to-a-long-random-string



# Admin dashboard (/admin) — required for staff access

ADMIN_PASSWORD=change-me-to-a-strong-password

ADMIN_SECRET=change-me-to-a-long-random-string



# PostgreSQL for production (required on Vercel). Local dev can omit this (uses data/iron-lion.db).

# Neon: use the *pooled* connection string (host contains -pooler) for serverless/Vercel.

# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require



# Optional: POST each registration to Zapier, Make, HubSpot, etc.

# REGISTER_WEBHOOK_URL=https://hooks.example.com/...



# Optional: per-practitioner Calendly URLs (override content/site.ts defaults)

# CALENDLY_URL_JOHARI_TEMPLIN_JR=https://calendly.com/your-account/johari

# CALENDLY_URL_JOHNNY_LONA=https://calendly.com/your-account/johnny
# CALENDLY_URL_DUAL_SESSION=https://calendly.com/your-account/dual-session



# Optional[bool] Email notifications via Resend (https://resend.com)

# RESEND_API_KEY=re_...

# RESEND_FROM=Iron Lion <hello@yourdomain.com>

# ADMIN_NOTIFY_EMAIL=ironlionhealing@gmail.com



# Optional: AI-assisted wellness guide

# OPENAI_API_KEY=sk-...

# OPENAI_MODEL=gpt-4o-mini

